# VeeCode DevPortal — environment configuration
#
# Usage:
#   cp .env.example .env
#   # edit this file, then:
#   docker compose up -d
#
# Presets selected here drive what plugins load and which vars below are required.
# Add only the sections for the presets you selected.

# ─────────────────────────────────────────────────────────────────────────────
# Core — always required
# ─────────────────────────────────────────────────────────────────────────────

# Comma-separated list of presets to activate (no spaces).
# `recommended` enables marketplace, RBAC UI, tech-radar, pending-changes.
# `veecode-theme` applies the VeeCode brand palette.
VEECODE_PRESETS=recommended,veecode-theme

# ─────────────────────────────────────────────────────────────────────────────
# github — GitHub catalog provider + scaffolder + Actions UI tab
# Add `github` to VEECODE_PRESETS to activate.
# ─────────────────────────────────────────────────────────────────────────────

# GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GITHUB_ORG=my-org

# ─────────────────────────────────────────────────────────────────────────────
# github-auth — GitHub OAuth login (includes github vars above)
# Add `github-auth` to VEECODE_PRESETS to activate.
# ─────────────────────────────────────────────────────────────────────────────

# GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GITHUB_ORG=my-org
# GITHUB_AUTH_CLIENT_ID=Iv1.xxxxxxxxxxxxxxxxxxxx
# GITHUB_AUTH_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────────────────────
# gitlab — GitLab OAuth + integration + catalog provider
# Add `gitlab` to VEECODE_PRESETS to activate.
# ─────────────────────────────────────────────────────────────────────────────

# GITLAB_HOST=gitlab.example.com
# GITLAB_AUTH_CLIENT_ID=xxxxxxxxxxxx
# GITLAB_AUTH_CLIENT_SECRET=xxxxxxxxxxxx
# GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx
# GITLAB_GROUP=my-group

# ─────────────────────────────────────────────────────────────────────────────
# keycloak — Keycloak / OIDC sign-in + user/group sync
# Add `keycloak` to VEECODE_PRESETS to activate.
# ─────────────────────────────────────────────────────────────────────────────

# KEYCLOAK_BASE_URL=https://keycloak.example.com/auth
# KEYCLOAK_REALM=my-realm
# KEYCLOAK_CLIENT_ID=backstage
# KEYCLOAK_CLIENT_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# AUTH_SESSION_SECRET=<run: openssl rand -base64 32>

# ─────────────────────────────────────────────────────────────────────────────
# azure — Azure DevOps catalog + scaffolder + pipelines UI
# Add `azure` to VEECODE_PRESETS to activate.
# ─────────────────────────────────────────────────────────────────────────────

# AZURE_DEVOPS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AZURE_DEVOPS_HOST=dev.azure.com
# AZURE_DEVOPS_ORG=my-org
# AZURE_DEVOPS_PROJECT=my-project

# ─────────────────────────────────────────────────────────────────────────────
# azure-auth — Microsoft / Entra ID sign-in
# Add `azure-auth` to VEECODE_PRESETS to activate.
# ─────────────────────────────────────────────────────────────────────────────

# AZURE_AUTH_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# AZURE_AUTH_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# AZURE_AUTH_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────────────────────
# kubernetes — Kubernetes workloads tab
# Add `kubernetes` to VEECODE_PRESETS to activate.
# ─────────────────────────────────────────────────────────────────────────────

# K8S_CLUSTER_NAME=my-cluster
# K8S_CLUSTER_URL=https://kubernetes.example.com
# K8S_CLUSTER_TOKEN=xxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────────────────────
# sonarqube — SonarQube code quality tab + scaffolder action
# Add `sonarqube` to VEECODE_PRESETS to activate.
# ─────────────────────────────────────────────────────────────────────────────

# SONARQUBE_BASE_URL=https://sonarqube.example.com
# SONARQUBE_API_KEY=xxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────────────────────
# jenkins — Jenkins CI tab
# Add `jenkins` to VEECODE_PRESETS to activate.
# ─────────────────────────────────────────────────────────────────────────────

# JENKINS_URL=https://jenkins.example.com
# JENKINS_USERNAME=admin
# JENKINS_TOKEN=xxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────────────────────
# ldap — LDAP sign-in + user/group sync
# Add `ldap` to VEECODE_PRESETS to activate.
# ─────────────────────────────────────────────────────────────────────────────

# LDAP_URL=ldap://ldap.example.com
# LDAP_DN=cn=admin,dc=example,dc=com
# LDAP_SECRET=xxxxxxxxxxxx
# LDAP_USERS_BASE_DN=ou=users,dc=example,dc=com
# LDAP_GROUPS_BASE_DN=ou=groups,dc=example,dc=com

# ─────────────────────────────────────────────────────────────────────────────
# mcp-chat — AI chat UI in the portal
# Add `mcp,mcp-chat` to VEECODE_PRESETS to activate (mcp is required by mcp-chat).
# ─────────────────────────────────────────────────────────────────────────────

# MCP_CHAT_PROVIDER=anthropic
# MCP_CHAT_API_KEY=sk-ant-xxxxxxxxxxxx
# MCP_CHAT_MODEL=claude-sonnet-4-6

# ─────────────────────────────────────────────────────────────────────────────
# Advanced — override defaults only if needed
# ─────────────────────────────────────────────────────────────────────────────

# Plugin OCI registry (default: quay.io/veecode). Override for air-gapped clusters.
# PLUGIN_REGISTRY=registry.internal/veecode
